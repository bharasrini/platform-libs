{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "noEmit": true,
    "allowJs": true,          // <-- JS files participate
    "checkJs": true,          // <-- actually type-check JS
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": [
    "packages/**/src/**/*",
    "packages/**/test/**/*",
    "packages/**/data/**/*"
  ]
}
