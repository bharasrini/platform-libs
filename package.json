{
	"name": "platform",
	"private": true,
	"type": "commonjs",
	"workspaces": 
	[
		"packages/*",
		"services/*",
		"apps/*"
	],
	
	"dependencies": 
	{
		"@aws-sdk/client-s3": "^3.1000.0",
		"date-fns": "^4.1.0",
		"date-fns-tz": "^3.2.0",
		"dotenv": "^17.2.3",
		"exceljs": "^4.1.1",
		"googleapis": "^171.4.0",
		"mime-types": "^3.0.2",
		"util": "^0.12.5"
	},
	
	"devDependencies":
	{
		"@eslint/css": "^0.14.1",
		"@eslint/js": "^10.0.1",
		"@eslint/json": "^1.0.1",
		"@eslint/markdown": "^7.5.1",
		"eslint": "^10.0.1",
		"globals": "^17.3.0",
		"concurrently": "^9.0.1"
	},
	
	"scripts": 
	{
		"dev:ui": "pnpm --filter ops-ui dev",
		"dev:api": "pnpm --filter api dev",
		"dev": "concurrently \"pnpm dev:api\" \"pnpm dev:ui\""
	}
}
